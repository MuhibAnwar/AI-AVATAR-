# ============================================
# AvaAI Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your API keys

# --- Anthropic (Claude AI) ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- OpenAI (Whisper STT) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Groq (free: STT + AI chat) ---
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- ElevenLabs (Text-to-Speech) ---
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Get a Voice ID from: https://elevenlabs.io/app/voice-library
# Recommended: "Rachel" = 21m00Tcm4TlvDq8ikWAM  or  "Bella" = EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- D-ID (Avatar Animation + Lip Sync) ---
# Get from: https://studio.d-id.com/account-settings
DID_API_KEY=your_did_api_key_here
# Presenter image URL (public image for the avatar face)
# You can use any public HTTPS image URL, or leave default
DID_PRESENTER_URL=https://create-images-results.d-id.com/api_docs/assets/noelle.jpeg

# --- Neon PostgreSQL (call history) ---
# Get from: https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Tavily (Web Search for Ava) ---
# Get free key from: https://app.tavily.com (1000 searches/month free)
TAVILY_API_KEY=your_tavily_api_key_here

# --- Resend (Welcome Email) ---
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
# Verified sender — must match a domain you've verified in Resend
# While testing you can use: onboarding@resend.dev
RESEND_FROM_EMAIL=Ava <ava@yourdomain.com>

# --- Clerk Webhook ---
# Get from: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret_here

# --- Server ---
PORT=3001
# PUBLIC_URL is used so D-ID can fetch ElevenLabs audio from your server.
# In development: use a tunnel like ngrok → https://yoursubdomain.ngrok.io
# In production: your deployed backend URL → https://your-api.example.com
PUBLIC_URL=http://localhost:3001
# Frontend URL — used for welcome email CTA button
FRONTEND_URL=http://localhost:5173
